{
  "compilerOptions": {
    // --- Layout de archivos (ACTIVALOS) ---
    "rootDir": "./src",      // Donde escribís el código .ts
    "outDir": "./dist",     // Donde se genera el código .js final

    // --- Configuración de Entorno ---
    "module": "NodeNext",
    "moduleResolution": "NodeNext", // Agregá esta línea para que reconozca bien los imports
    "target": "ESNext",
    
    // --- Tipos de Node (IMPORTANTE) ---
    "types": ["node"], // Asegurate de tener instalado: npm install -D @types/node

    // --- Calidad y Strict ---
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true, // Agregá esto para que las librerías viejas funcionen con TS
    
    // El resto lo podés dejar como está, pero estos son los vitales para arrancar.
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],    // Le decimos a TS que solo mire lo que está en /src
  "exclude": ["node_modules"] // Que ignore la carpeta de librerías
}